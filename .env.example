# ═══════════════════════════════════════════════════════════════════════════
# Contribution Factor Model v3.0 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in with your institution's values.
# DO NOT commit .env — it contains sensitive credentials.
#
# ═══════════════════════════════════════════════════════════════════════════

# GitLab Instance
# For gitlab.com, use: https://gitlab.com
# For self-hosted, use: https://gitlab.suainstituicao.edu.br (or your URL)
GITLAB_URL=https://gitlab.com

# GitLab Personal Access Token
# Create at: {GITLAB_URL}/-/user_settings/personal_access_tokens
# Required scopes: api, read_repository
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Project identifier
# Can be:
#   - Numeric ID: 123456
#   - Namespace/slug: grupo/seu-projeto
GITLAB_PROJECT=namespace/repositorio

# Local repository path
# Absolute path to the cloned repository (for git blame and survival calculation)
REPO_PATH=/caminho/absoluto/do/repositorio/clonado

# SSL Verification
# Set to 'false' if using self-hosted GitLab with self-signed certificate
# WARNING: Only use false in trusted academic environments
GITLAB_SSL_VERIFY=true
